# Local Gemini Developer API mode.
# Get a key from Google AI Studio, then copy this file to .env locally.
GEMINI_API_KEY=

# Google Cloud / Gemini Enterprise Agent Platform mode.
# Prefer this for Cloud Run with Application Default Credentials or the service account identity.
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# Optional.
# GEMINI_MODEL=gemini-2.5-flash
# PORT=3000
