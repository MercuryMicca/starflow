# Local Gemini Developer API mode.
# Get a key from Google AI Studio, then copy this file to .env locally.
GEMINI_API_KEY=

# Google Cloud / Gemini Enterprise Agent Platform mode.
# If GOOGLE_AGENT_PLATFORM_KEY is set, the app prefers Agent Platform mode.
# Keep this server-side only; never expose it to browser JavaScript.
# GOOGLE_AGENT_PLATFORM_KEY=
#
# Optional metadata used for deploys and diagnostics.
# GEMINI_PROJECT_NUMBER=your-project-number
#
# For Cloud Run with Application Default Credentials or service account identity,
# omit GOOGLE_AGENT_PLATFORM_KEY and set GOOGLE_CLOUD_PROJECT. The enterprise
# flag is optional in that case, but can be set to make the intended mode explicit.
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# Optional.
# GEMINI_MODEL=gemini-2.5-flash
# PORT=3000
